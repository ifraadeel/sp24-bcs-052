<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — Oura</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: #f0ebe3;
      color: #1a1a1a;
    }

    /* ── PAGE HEADER ── */
    .page-header {
      margin-bottom: 36px;
    }
    .page-label {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #8a8278;
      margin-bottom: 8px;
    }
    .page-title {
      font-family: 'Playfair Display', serif;
      font-size: 2.2rem;
      font-weight: 400;
    }

    /* ── SUMMARY CARDS ── */
    .summary-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 40px;
    }
    .card {
      background: #fdfcfa;
      border: 1px solid #d8d2c8;
      border-radius: 8px;
      padding: 24px 28px;
    }
    .card-label {
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #8a8278;
      margin-bottom: 10px;
    }
    .card-value {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 400;
    }

    /* ── TABLE SECTION ── */
    .table-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 18px;
    }
    .table-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 400;
    }
    .btn-add {
      background: #1a1a1a;
      color: #fdfcfa;
      padding: 10px 22px;
      border-radius: 50px;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      transition: background 0.2s;
    }
    .btn-add:hover { background: #3a3a3a; }

    .table-wrap {
      background: #fdfcfa;
      border: 1px solid #d8d2c8;
      border-radius: 8px;
      overflow: hidden;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }
    thead {
      background: #1a1a1a;
      color: #fdfcfa;
    }
    thead th {
      padding: 14px 20px;
      text-align: left;
      font-weight: 500;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    tbody tr {
      border-bottom: 1px solid #e4ddd3;
      transition: background 0.15s;
    }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #f5f0e8; }
    td {
      padding: 14px 20px;
      color: #3a3a3a;
      vertical-align: middle;
    }

    .td-name {
      font-family: 'Playfair Display', serif;
      font-size: 0.98rem;
      color: #1a1a1a;
    }
    .td-category {
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #8a8278;
    }
    .stock-ok  { color: #5a8a5a; font-weight: 500; }
    .stock-low { color: #c07a30; font-weight: 500; }
    .stock-out { color: #a05252; font-weight: 500; }

    /* ── ACTION BUTTONS ── */
    .actions { display: flex; gap: 8px; }

    .btn-edit {
      padding: 7px 16px;
      border: 1px solid #d8d2c8;
      border-radius: 50px;
      background: transparent;
      color: #1a1a1a;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.8rem;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.2s;
      cursor: pointer;
    }
    .btn-edit:hover {
      background: #1a1a1a;
      color: #fdfcfa;
      border-color: #1a1a1a;
    }

    .btn-delete {
      padding: 7px 16px;
      border: 1px solid #e0c8c8;
      border-radius: 50px;
      background: transparent;
      color: #a05252;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.8rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-delete:hover {
      background: #a05252;
      color: #fdfcfa;
      border-color: #a05252;
    }

    /* ── EMPTY STATE ── */
    .empty-row td {
      text-align: center;
      padding: 60px;
      color: #8a8278;
      font-size: 0.95rem;
    }

    /* ── CONFIRM MODAL ── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.45);
      z-index: 999;
      align-items: center;
      justify-content: center;
    }
    .modal-overlay.show { display: flex; }

    .modal {
      background: #fdfcfa;
      border-radius: 10px;
      padding: 40px 44px;
      max-width: 400px;
      width: 90%;
      text-align: center;
    }
    .modal-icon { font-size: 2rem; margin-bottom: 14px; }
    .modal-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      margin-bottom: 10px;
    }
    .modal-text {
      font-size: 0.88rem;
      color: #8a8278;
      margin-bottom: 28px;
      line-height: 1.6;
    }
    .modal-actions { display: flex; gap: 12px; justify-content: center; }
    .modal-cancel {
      padding: 10px 24px;
      border: 1px solid #d8d2c8;
      border-radius: 50px;
      background: transparent;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .modal-cancel:hover { background: #f0ebe3; }
    .modal-confirm {
      padding: 10px 24px;
      border: none;
      border-radius: 50px;
      background: #a05252;
      color: white;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.85rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .modal-confirm:hover { background: #8a3a3a; }
  </style>
</head>
<body>

  <%- include('../partials/adminNav', { activePage: 'dashboard' }) %>

  <div class="admin-main">

    <!-- Header -->
    <div class="page-header">
      <p class="page-label">Admin Panel</p>
      <h1 class="page-title">Product Dashboard</h1>
    </div>

    <!-- Summary Cards -->
    <div class="summary-cards">
      <div class="card">
        <p class="card-label">Total Products</p>
        <p class="card-value"><%= products.length %></p>
      </div>
      <div class="card">
        <p class="card-label">In Stock</p>
        <p class="card-value"><%= products.filter(p => p.stock > 0).length %></p>
      </div>
      <div class="card">
        <p class="card-label">Out of Stock</p>
        <p class="card-value"><%= products.filter(p => p.stock === 0).length %></p>
      </div>
    </div>

    <!-- Table -->
    <div class="table-header">
      <h2 class="table-title">All Products</h2>
      <a href="/admin/new" class="btn-add">＋ Add Product</a>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Category</th>
            <th>Price (Rs.)</th>
            <th>Stock</th>
            <th>Rating</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (products.length === 0) { %>
            <tr class="empty-row">
              <td colspan="6">No products yet. <a href="/admin/new" style="color:#1a1a1a;">Add one.</a></td>
            </tr>
          <% } else { %>
            <% products.forEach(product => { %>
              <tr>
                <td class="td-name"><%= product.name %></td>
                <td class="td-category"><%= product.category %></td>
                <td>Rs. <%= product.price.toLocaleString() %></td>
                <td>
                  <% if (product.stock === 0) { %>
                    <span class="stock-out">Out of Stock</span>
                  <% } else if (product.stock <= 5) { %>
                    <span class="stock-low"><%= product.stock %> low</span>
                  <% } else { %>
                    <span class="stock-ok"><%= product.stock %> units</span>
                  <% } %>
                </td>
                <td>⭐ <%= product.rating %></td>
                <td>
                  <div class="actions">
                    <a href="/admin/edit/<%= product._id %>" class="btn-edit">Edit</a>
                    <!-- Delete triggers modal, not a direct form submit -->
                    <button class="btn-delete" onclick="confirmDelete('<%= product._id %>', '<%= product.name %>')">Delete</button>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>

  </div><!-- /admin-main -->

  <!-- ── DELETE CONFIRMATION MODAL ── -->
  <div class="modal-overlay" id="deleteModal">
    <div class="modal">
      <div class="modal-icon">⚠️</div>
      <h3 class="modal-title">Delete Product?</h3>
      <p class="modal-text" id="modalText">This will permanently remove the product from the database.</p>
      <div class="modal-actions">
        <button class="modal-cancel" onclick="closeModal()">Cancel</button>
        <!-- This form's action is set dynamically by JS -->
        <form id="deleteForm" method="POST" style="display:inline;">
          <button type="submit" class="modal-confirm">Yes, Delete</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    // Show modal and set the form action to the correct product ID
    function confirmDelete(id, name) {
      document.getElementById('modalText').textContent =
        `This will permanently remove "${name}" from the database.`;
      document.getElementById('deleteForm').action = '/admin/delete/' + id;
      document.getElementById('deleteModal').classList.add('show');
    }

    function closeModal() {
      document.getElementById('deleteModal').classList.remove('show');
    }

    // Close modal if user clicks outside the box
    document.getElementById('deleteModal').addEventListener('click', function(e) {
      if (e.target === this) closeModal();
    });
  </script>

</body>
</html>
