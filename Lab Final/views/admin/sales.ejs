<div class="sales-dashboard">
  <h1>📊 Real-Time Sales Dashboard</h1>
  
  <div class="stats-grid">
    <!-- Total Revenue Card -->
    <div class="stat-card revenue-card">
      <div class="stat-icon">💰</div>
      <div class="stat-content">
        <h3>Total Revenue</h3>
        <p class="stat-value" id="totalRevenue">$<%= totalRevenue.toFixed(2) %></p>
      </div>
    </div>

    <!-- Total Orders Card -->
    <div class="stat-card orders-card">
      <div class="stat-icon">📦</div>
      <div class="stat-content">
        <h3>Total Orders</h3>
        <p class="stat-value" id="totalOrders"><%= totalOrders %></p>
      </div>
    </div>

    <!-- Top Product Card -->
    <div class="stat-card product-card">
      <div class="stat-icon">🏆</div>
      <div class="stat-content">
        <h3>Top-Selling Product</h3>
        <% if (topProduct) { %>
          <p class="stat-value" id="topProductName"><%= topProduct.productName %></p>
          <p class="stat-detail" id="topProductQty">Sold: <span id="topProductQuantity"><%= topProduct.totalQuantity %></span> units</p>
        <% } else { %>
          <p class="stat-value">No sales yet</p>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Recent Orders Table -->
  <div class="recent-orders">
    <h2>Recent Orders</h2>
    <div class="table-container" id="recentOrdersTable">
      <table>
        <thead>
          <tr>
            <th>Order ID</th>
            <th>Customer</th>
            <th>Amount</th>
            <th>Date</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="ordersTableBody">
          <% recentOrders.forEach(order => { %>
            <tr>
              <td>#<%= order._id.toString().slice(-6) %></td>
              <td><%= order.userId?.username || 'Guest' %></td>
              <td>$<%= order.totalAmount.toFixed(2) %></td>
              <td><%= new Date(order.createdAt).toLocaleDateString() %></td>
              <td><span class="status-badge <%= order.status %>"><%= order.status %></span></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="live-indicator">
    <span class="pulse-dot"></span>
    <span>Live updates every 10 seconds</span>
    <span id="lastUpdated"></span>
  </div>
</div>

<!-- jQuery for AJAX Polling -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
$(document).ready(function() {
  let updateInterval;
  
  function updateDashboard() {
    $.ajax({
      url: '/admin/api/sales-data',
      method: 'GET',
      success: function(data) {
        // Update stats
        $('#totalRevenue').text('$' + data.totalRevenue.toFixed(2));
        $('#totalOrders').text(data.totalOrders);
        
        if (data.topProduct) {
          $('#topProductName').text(data.topProduct.productName);
          $('#topProductQuantity').text(data.topProduct.totalQuantity);
        }
        
        // Update recent orders table
        updateOrdersTable(data.recentOrders);
        
        // Update timestamp
        const now = new Date();
        $('#lastUpdated').text('Last updated: ' + now.toLocaleTimeString());
        
        // Add flash animation
        $('.stat-value').addClass('flash');
        setTimeout(() => $('.stat-value').removeClass('flash'), 500);
      },
      error: function(xhr, status, error) {
        console.error('Failed to fetch sales data:', error);
      }
    });
  }
  
  function updateOrdersTable(orders) {
    const tbody = $('#ordersTableBody');
    tbody.empty();
    
    orders.forEach(order => {
      const date = new Date(order.createdAt).toLocaleDateString();
      const orderId = order._id.slice(-6);
      const customer = order.userId?.username || 'Guest';
      
      tbody.append(`
        <tr>
          <td>#${orderId}</td>
          <td>${customer}</td>
          <td>$${order.totalAmount.toFixed(2)}</td>
          <td>${date}</td>
          <td><span class="status-badge ${order.status}">${order.status}</span></td>
        </tr>
      `);
    });
  }
  
  // Start polling every 10 seconds
  updateInterval = setInterval(updateDashboard, 10000);
  
  // Initial timestamp
  const now = new Date();
  $('#lastUpdated').text('Last updated: ' + now.toLocaleTimeString());
  
  // Clean up on page unload
  $(window).on('beforeunload', function() {
    clearInterval(updateInterval);
  });
});
</script>

<style>
.sales-dashboard {
  padding: 30px;
  max-width: 1400px;
  margin: 0 auto;
}

.sales-dashboard h1 {
  color: #0D0D0D;
  margin-bottom: 30px;
  font-size: 2.5rem;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 25px;
  margin-bottom: 40px;
}

.stat-card {
  background: white;
  border-radius: 15px;
  padding: 30px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  display: flex;
  align-items: center;
  gap: 20px;
  transition: transform 0.3s, box-shadow 0.3s;
}

.stat-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 25px rgba(0,0,0,0.15);
}

.revenue-card {
  border-left: 5px solid #34C759;
}

.orders-card {
  border-left: 5px solid #007AFF;
}

.product-card {
  border-left: 5px solid #FFD700;
}

.stat-icon {
  font-size: 3rem;
}

.stat-content h3 {
  color: #666;
  font-size: 1rem;
  margin-bottom: 10px;
  font-weight: 500;
}

.stat-value {
  font-size: 2.5rem;
  font-weight: bold;
  color: #0D0D0D;
  margin: 0;
  transition: all 0.3s;
}

.stat-value.flash {
  transform: scale(1.1);
  color: #007AFF;
}

.stat-detail {
  font-size: 0.9rem;
  color: #999;
  margin-top: 5px;
}

.recent-orders {
  background: white;
  border-radius: 15px;
  padding: 30px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  margin-bottom: 30px;
}

.recent-orders h2 {
  margin-bottom: 20px;
  color: #0D0D0D;
}

.table-container {
  overflow-x: auto;
}

table {
  width: 100%;
  border-collapse: collapse;
}

thead {
  background: #F5F5F7;
}

th, td {
  padding: 15px;
  text-align: left;
  border-bottom: 1px solid #E5E5E5;
}

th {
  font-weight: 600;
  color: #666;
  font-size: 0.9rem;
  text-transform: uppercase;
}

td {
  color: #0D0D0D;
}

.status-badge {
  padding: 5px 12px;
  border-radius: 20px;
  font-size: 0.85rem;
  font-weight: 500;
}

.status-badge.completed {
  background: #D1F4E0;
  color: #0A8754;
}

.status-badge.pending {
  background: #FFE5B4;
  color: #C87000;
}

.status-badge.cancelled {
  background: #FFD7D7;
  color: #C41E3A;
}

.live-indicator {
  display: flex;
  align-items: center;
  gap: 10px;
  justify-content: center;
  color: #666;
  font-size: 0.9rem;
}

.pulse-dot {
  width: 10px;
  height: 10px;
  background: #34C759;
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.5;
    transform: scale(1.2);
  }
}

#lastUpdated {
  color: #999;
  font-style: italic;
}
</style>